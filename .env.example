# Copy to .env (for local runs) or pass these as -e flags to the container.

# Local-only: simulate the Cloudflare Access identity header so you can run without a tunnel.
# Leave UNSET in production — the app refuses requests with no Access header.
DEV_EMAIL=you@example.com

# Comma-separated admin emails (admins see every user's runs/scores).
ADMIN_EMAILS=you@example.com

# Optional: pre-name initial users (JSON). Unknown users auto-create on first sign-in.
# SEED_USERS=[{"email":"you@example.com","name":"You","role":"admin"},{"email":"kid@example.com","name":"Kid","role":"user"}]

# Server / storage (defaults shown)
PORT=8080
HOST=0.0.0.0
DB_PATH=/data/quiz.db
